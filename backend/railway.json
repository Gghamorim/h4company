{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn server:app --host 0.0.0.0 --port $PORT"
  },
  "environments": [
    {
      "name": "production",
      "environmentVariables": {
        "DATABASE_URL": "status_checks.db",
        "CORS_ORIGINS": "*"
      }
    }
  ]
}