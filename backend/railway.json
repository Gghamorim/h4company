{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn server:app --host 0.0.0.0 --port $PORT"
  },
  "environments": [
    {
      "name": "production",
      "environmentVariables": {
        "MONGO_URL": "mongodb://localhost:27017",
        "DB_NAME": "h4company_prod",
        "CORS_ORIGINS": "*"
      }
    }
  ]
}